# ── Serve .py files as plain text instead of CGI ──────────────────────
# Without this, requesting any .py URL triggers Apache's CGI handler
# and returns 500 (the scripts aren't set up for CGI). ForceType makes
# them readable as source in the browser, which is what we want for
# /development/scripts/* and any future Python uploads.
<FilesMatch "\.py$">
  SetHandler default-handler
  ForceType text/plain
</FilesMatch>

# ── 301 redirects: Sandbox/* → development/* (moved 2026-05) ──────────
# Permanent redirects for items that graduated out of /Sandbox/ into
# /development/. Old bookmarks, social links, and search-engine results
# auto-forward. Listed before the case-insensitive aliases so a request
# like /Sandbox/cedar-siding-calculator/ is redirected before the alias
# rule has a chance to fire.
<IfModule mod_rewrite.c>
RewriteEngine On

RedirectMatch 301 ^/Sandbox/cedar-siding-calculator(/.*)?$ /development/cedar-siding-calculator$1
RedirectMatch 301 ^/Sandbox/accumulatedDrifts(/.*)?$       /development/accumulatedDrifts$1
RedirectMatch 301 ^/Sandbox/experiment1(/.*)?$             /development/experiment1$1
RedirectMatch 301 ^/Sandbox/SidingCalculator-old(/.*)?$    /development/SidingCalculator-old$1
RedirectMatch 301 ^/Sandbox/generate_music\.py$            /development/scripts/generate_music.py
RedirectMatch 301 ^/development/generate_music\.py$        /development/scripts/generate_music.py

# TestCases/_shared/ promoted to top-level /widgets/ (2026-05-13)
RedirectMatch 301 ^/TestCases/_shared(/.*)?$               /widgets$1

# buffer-shuffler was a duplicate stub in TestCases — canonical lives at
# /web-instruments/buffer-shuffler/. Replaces an HTML meta-refresh stub.
RedirectMatch 301 ^/TestCases/buffer-shuffler(/.*)?$       /web-instruments/buffer-shuffler$1
</IfModule>

# ── Case-insensitive aliases for browsable directories ────────────────
# Without these, /testcases/ misses the disk path /TestCases/, falls
# through to the WordPress catch-all below, and ends up redirecting to
# /glitchpage/. The case-sensitive RewriteCond skips the rewrite when
# the URL is already correctly cased — otherwise the [NC] match would
# loop the rewriter on the canonical path. Kept OUTSIDE the WordPress
# markers so `wp-admin → Settings → Permalinks` won't overwrite them.
<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{REQUEST_URI} !^/TestCases
RewriteRule ^testcases(/.*)?$ /TestCases$1 [NC,L]

RewriteCond %{REQUEST_URI} !^/Sandbox
RewriteRule ^sandbox(/.*)?$ /Sandbox$1 [NC,L]
</IfModule>

# BEGIN WordPress
# The directives (lines) between "BEGIN WordPress" and "END WordPress" are
# dynamically generated, and should only be modified via WordPress filters.
# Any changes to the directives between these markers will be overwritten.
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteBase /
RewriteRule ^index\.php$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
</IfModule>

# END WordPress
